# =================================================================
# SentinelAI - Environment Configuration Template
# =================================================================
# 📋 SETUP INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit .env to version control!
# =================================================================

# -----------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------
SENTINEL_ENVIRONMENT=development
# Options: development, staging, production

# -----------------------------------------------------------------
# LLM Configuration (REQUIRED)
# -----------------------------------------------------------------
SENTINEL_LLM_PROVIDER=huggingface
# Options: groq, huggingface

# Groq Settings (Primary LLM Provider - Fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
SENTINEL_LLM_GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace Settings (RAG + Alternative LLM)
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here
SENTINEL_LLM_HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta
# Alternative specialized models:
# - Bilic/Mistral-7B-LLM-Fraud-Detection (fraud detection)
# - ProsusAI/finbert (financial sentiment)
# - meta-llama/Meta-Llama-3.1-70B-Instruct (general purpose)

# LLM Parameters
SENTINEL_LLM_TEMPERATURE=0.0
SENTINEL_LLM_MAX_TOKENS=4096
SENTINEL_LLM_MAX_RETRIES=3
SENTINEL_LLM_TIMEOUT=60

# -----------------------------------------------------------------
# RAG (Retrieval-Augmented Generation) Configuration
# -----------------------------------------------------------------
# Web Search Providers (Optional - DuckDuckGo works without keys)
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Get your key at: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# RAG Settings
SENTINEL_RAG_ENABLE_WEB_SEARCH=true
SENTINEL_RAG_SEARCH_DEPTH=standard
# Options: basic, standard, deep

# -----------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------
# PostgreSQL (Required for production)
SENTINEL_DB_POSTGRES_HOST=localhost
SENTINEL_DB_POSTGRES_PORT=5432
SENTINEL_DB_POSTGRES_USER=sentinel
SENTINEL_DB_POSTGRES_PASSWORD=your_postgres_password_here
SENTINEL_DB_POSTGRES_DB=sentinelai

# Redis (Optional - for caching)
SENTINEL_DB_REDIS_HOST=localhost
SENTINEL_DB_REDIS_PORT=6379
# SENTINEL_DB_REDIS_PASSWORD=your_redis_password_here

# Neo4j (Required for Graph Analysis)
# Local: neo4j://localhost:7687
# Cloud (AuraDB): neo4j+s://xxxxxxxx.databases.neo4j.io
# Get free cloud instance at: https://neo4j.com/cloud/aura-free/
SENTINEL_DB_NEO4J_URI=neo4j://localhost:7687
SENTINEL_DB_NEO4J_USER=neo4j
SENTINEL_DB_NEO4J_PASSWORD=your_neo4j_password_here

# -----------------------------------------------------------------
# API Server Settings
# -----------------------------------------------------------------
SENTINEL_API_HOST=0.0.0.0
SENTINEL_API_PORT=8000
SENTINEL_API_WORKERS=4
SENTINEL_API_RELOAD=false
SENTINEL_API_DEBUG=false

# CORS (comma-separated origins, use ["*"] for development only)
SENTINEL_API_CORS_ORIGINS=["*"]

# Rate Limiting
SENTINEL_API_RATE_LIMIT_REQUESTS=100
SENTINEL_API_RATE_LIMIT_PERIOD=60

# Authentication (Generate with: openssl rand -hex 32)
SENTINEL_API_JWT_SECRET=your_jwt_secret_generate_with_openssl_rand_hex_32
SENTINEL_API_JWT_ALGORITHM=HS256
SENTINEL_API_JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------------
# Risk Configuration
# -----------------------------------------------------------------
SENTINEL_RISK_LOW_RISK_THRESHOLD=30
SENTINEL_RISK_MEDIUM_RISK_THRESHOLD=60
SENTINEL_RISK_HIGH_RISK_THRESHOLD=80
SENTINEL_RISK_CRITICAL_RISK_THRESHOLD=95

SENTINEL_RISK_LARGE_TRANSACTION_THRESHOLD=10000
SENTINEL_RISK_VERY_LARGE_TRANSACTION_THRESHOLD=100000
SENTINEL_RISK_STRUCTURING_THRESHOLD=9500

# -----------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------
SENTINEL_MONITOR_LOG_LEVEL=INFO
SENTINEL_MONITOR_LOG_FORMAT=json
# Options: json, text
SENTINEL_MONITOR_LOG_FILE=logs/sentinelai.log

SENTINEL_MONITOR_METRICS_ENABLED=true
SENTINEL_MONITOR_METRICS_PORT=9090

# Tracing (OpenTelemetry/Jaeger - Optional)
SENTINEL_MONITOR_TRACING_ENABLED=false
SENTINEL_MONITOR_JAEGER_HOST=localhost
SENTINEL_MONITOR_JAEGER_PORT=6831
